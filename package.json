{
  "name": "overlaychat-desktop",
  "version": "1.0.9",
  "description": "Windows overlay app for OverlayChat",
  "author": "OverlayChat",
  "main": "desktop/main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.overlaychat.desktop",
    "productName": "OverlayChat",
    "directories": {
      "buildResources": "desktop"
    },
    "files": [
      "desktop/**/*",
      "assets/**/*",
      "overlay.html",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  },
  "devDependencies": {
    "electron": "37.3.1",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "dotenv": "^16.4.5",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.0.0"
  }
}
